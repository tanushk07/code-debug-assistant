# =====================================================================
#  Backend environment variables — copy this to .env and fill in.
# =====================================================================

# --- Database (Neon Postgres) ---
# Create a project at https://neon.tech and paste the pooled connection string.
DATABASE_URL=

# --- Auth ---
# Generate:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# --- LLM providers (set ONE — the app picks whichever is configured) ---
# Free, fast — recommended.  https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Free tier.  https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Paid.  https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Paid.  https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Default provider when the UI doesn't override (groq | gemini | gpt | claude)
DEFAULT_LLM=groq

# --- Object storage (Cloudflare R2, S3-compatible) ---
# Free tier.  https://developers.cloudflare.com/r2/
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=debug-assistant-uploads
R2_PUBLIC_URL=

# --- App ---
FRONTEND_URL=http://localhost:5173
PORT=3001
